# NEC CRM — environment variables. Copy to .env and fill in.

# Frappe backend URL for API calls.
# Production (app served from the same domain as ERPNext): leave empty.
# Production (app on Vercel etc.): https://erp.yourdomain.com — CORS must allow it.
VITE_API_BASE_URL=

# Dev-only: where the Vite proxy forwards /api during `npm run dev`.
VITE_PROXY_TARGET=https://erp.yourdomain.com

# Base URL of the ERPNext desk, used for "open report" deep links in Manager view.
# Leave empty to use the same origin as the app.
VITE_DESK_BASE_URL=
