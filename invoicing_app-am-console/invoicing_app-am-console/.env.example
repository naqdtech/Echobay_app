# ──────────────────────────────────────
# Sales QR PWA — Environment Variables
# Copy this file to .env and fill in values
# ──────────────────────────────────────

# Frappe backend URL (no trailing slash)
# In production: https://yourdomain.com
# In development with proxy: leave empty
VITE_API_BASE_URL=

# UPI Payee VPA (your company's UPI ID)
VITE_UPI_VPA=yourcompany@upi

# UPI Payee Name (appears in payment apps)
VITE_UPI_PAYEE_NAME=Your Company Name
